rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidHazard(data) {
      return data.type is string 
          && data.location is latlng
          && data.geohash is string
          && data.reporterId == request.auth.uid
          && data.timestamp is timestamp;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      // Sub-collection for user reports
      match /my_reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHazard(request.resource.data);
        allow update: if isOwner(userId) && isValidHazard(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    // Public Hazards Collection
    match /public_hazards/{hazardId} {
      // Anyone signed in can read public hazards for warnings
      allow read: if isSignedIn();
      
      // Creating a public hazard:
      // In a real app, this might be triggered by a Cloud Function or a batch write
      // For this demo, we allow users to write to public_hazards if the reporterId matches.
      allow create: if isSignedIn() 
                   && isValidHazard(request.resource.data)
                   && request.resource.data.isPublic == true;
                   
      // Prevent updates/deletes to public records by standard users for integrity
      allow update, delete: if false; 
    }
  }
}
