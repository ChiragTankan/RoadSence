rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidHazard(data) {
      return data.type is string 
          && data.location is latlng
          && data.geohash is string
          && data.reporterId == request.auth.uid
          && data.timestamp is timestamp;
    }

    function isValidVoteUpdate() {
      let existing = resource.data;
      let incoming = request.resource.data;
      let diff = incoming.diff(existing);
      
      return isSignedIn() 
          && diff.affectedKeys().hasOnly(['deleteVotes', 'votedToDeleteBy'])
          && incoming.deleteVotes == (existing.get('deleteVotes', 0) + 1)
          && incoming.votedToDeleteBy.size() == (existing.get('votedToDeleteBy', []).size() + 1)
          && incoming.votedToDeleteBy.hasAll([request.auth.uid]);
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      // Sub-collection for user reports
      match /my_reports/{reportId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHazard(request.resource.data);
        allow update: if isOwner(userId) && isValidHazard(request.resource.data);
        allow delete: if isOwner(userId) || isSignedIn(); // Allow social deletion
      }
    }

    // Public Hazards Collection
    match /public_hazards/{hazardId} {
      // Anyone signed in can read public hazards for warnings
      allow read: if isSignedIn();
      
      // Creating a public hazard:
      allow create: if isSignedIn() 
                   && isValidHazard(request.resource.data)
                   && request.resource.data.isPublic == true;
                   
      // Allow community voting update
      allow update: if isValidVoteUpdate();

      // Allow community deletion
      allow delete: if isSignedIn(); 
    }
  }
}
